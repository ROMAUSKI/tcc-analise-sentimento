      {
       "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### UNIFICAÇÃO DOS ARQUIVOS DE APPS\n",
    "Lê os CSVs brutos gerados manualmente nas UIs e unifica em um único dataset."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"--- Iniciando unificação (APPS) ---\")\n",
    "print(f\"Procurando arquivos CSV em: {os.getcwd()}\")\n",
    "arquivos_csv = glob.glob('*.csv')\n",
    "lista_dataframes = []\n",
    "\n",
    "if not arquivos_csv:\n",
    "    print(\"⚠️ AVISO: Nenhum arquivo .csv encontrado em dados/brutos_apps/\")\n",
    "    print(\"Gere os arquivos nas IAs e salve-os nesta pasta antes de continuar.\")\n",
    "else:\n",
    "    for arquivo in arquivos_csv:\n",
    "        try:\n",
    "            df_temp = pd.read_csv(arquivo, header=None, names=['frase'], usecols=[0])\n",
    "            df_temp = df_temp.dropna(subset=['frase'])\n",
    "            \n",
    "            nome_arquivo = arquivo.lower()\n",
    "            if 'positive' in nome_arquivo: df_temp['classe'] = 'Positiva'\n",
    "            elif 'negative' in nome_arquivo: df_temp['classe'] = 'Negativa'\n",
    "            elif 'neutral' in nome_arquivo: df_temp['classe'] = 'Neutra'\n",
    "            \n",
    "            fonte = 'ChatGPT' if 'gpt' in nome_arquivo else ('Claude' if 'claude' in nome_arquivo else 'Gemini')\n",
    "            df_temp['fonte'] = fonte\n",
    "            lista_dataframes.append(df_temp)\n",
    "        except Exception as e: print(f\"Erro no arquivo {arquivo}: {e}\")\n",
    "\n",
    "    if lista_dataframes:\n",
    "        df_final = pd.concat(lista_dataframes, ignore_index=True)\n",
    "        df_final = df_final.sample(frac=1, random_state=42).reset_index(drop=True)\n",
    "        df_final.to_csv('../processado/dataset_apps_completo.csv', index=False)\n",
    "\n",
    "        print(f\"Total de frases: {len(df_final)}\")\n",
    "        print(df_final['classe'].value_counts())\n",
    "    else:\n",
    "        print(\"❌ ERRO: Falha ao carregar os dataframes. Verifique se os arquivos CSV estão no formato correto.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### PRÉ-PROCESSAMENTO E LIMPEZA (APPS)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if 'df_final' in locals():\n",
    "    def limpar_texto(texto):\n",
    "        texto = str(texto).lower()\n",
    "        texto = re.sub(r'[^a-zÀ-ÿ\\s]', '', texto)\n",
    "        return re.sub(r'\\s+', ' ', texto).strip()\n",
    "\n",
    "    df_final['frase_limpa'] = df_final['frase'].apply(limpar_texto)\n",
    "    df_final = df_final.drop_duplicates(subset=['frase_limpa']).reset_index(drop=True)\n",
    "    df_final.to_csv('../processado/synthetic_dataset_apps.csv', index=False)\n",
    "\n",
    "    print(f\"Dataset limpo salvo. Total de únicas: {len(df_final)}\")\n",
    "else:\n",
    "    print(\"⚠️ Execute a célula anterior com arquivos CSV carregados primeiro.\")"
   ]
  }
