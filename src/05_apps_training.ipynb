        "#Versões Atuais das Bibliotecas Instaladas\n",
        "import importlib.metadata\n",
        "libs = [\"pandas\", \"scikit-learn\", \"matplotlib\", \"seaborn\", \"nltk\", \"wordcloud\"]\n",
        "for lib in libs:\n",
